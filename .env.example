NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pr3cio
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/pr3cio
REDIS_URL=redis://localhost:6379

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_JWKS_URI=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

S3_REGION=us-east-1
S3_BUCKET_AUDIO=pr3cio-audio
S3_BUCKET_IMAGES=pr3cio-images
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

SUNO_API_BASE_URL=https://api.sunoapi.org/v1
SUNO_API_KEY=your-suno-api-key
SUNO_MODE=mock

HLS_SIGNED_URL_TTL_SECONDS=120
PLAYBACK_TOKEN_SECRET=replace-me

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYOUTS_ENABLED=false

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
