{
  "name": "pr3cio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "vercel-build": "turbo run build --filter=@pr3cio/web",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "turbo run format",
    "gemini": "gemini"
  },
  "dependencies": {
    "@prisma/client": "5.19.2",
    "next": "^14.2.35",
    "prisma": "5.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@google/gemini-cli": "^0.29.7",
    "@types/node": "^20.17.24",
    "eslint": "^9.21.0",
    "next": "^14.2.35",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "overrides": {
      "prisma": "5.19.2",
      "@prisma/client": "5.19.2"
    }
  }
}
